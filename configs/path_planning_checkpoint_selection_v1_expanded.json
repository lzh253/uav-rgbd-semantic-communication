{
  "run_name": "path_planning_checkpoint_selection_v1",
  "description": "Path planning checkpoint-selection comparison between best_model and last_model checkpoints.",
  "splits": [
    "val",
    "test"
  ],
  "image_size": 128,
  "thresholds": [
    0.05,
    0.1,
    0.15,
    0.2,
    0.25,
    0.3,
    0.35,
    0.4,
    0.45,
    0.5,
    0.55,
    0.6,
    0.65,
    0.7,
    0.75
  ],
  "selection_split": "val",
  "final_split": "test",
  "selection_metric": "success_rate_collision_free",
  "safety_selection_metric": "planning_safety_utility",
  "safety_selection_metric_definition": "success_rate_collision_free - (path_found_rate - success_rate_collision_free); rewards collision-free paths and penalizes found paths that collide.",
  "selection_tie_breakers": [
    "path_found_rate",
    "mean_map_iou",
    "negative_collision_rate_among_found"
  ],
  "min_gt_component_pixels": 300,
  "min_start_goal_distance": 32,
  "connectivity": 8,
  "max_samples_per_split": 0,
