{
  "run_family": "strict_rgb_depth_long_cuda_safe_baselines_v1",
  "description": "CUDA-safe long-run strict train/val/test baselines for road-only traversability prediction. Batch size is reduced to avoid GPU memory/driver instability while preserving the strict protocol.",
  "image_size": 128,
  "batch_size": 16,
  "num_epochs": 100,
  "learning_rate": 0.0002,
  "weight_decay": 0.00001,
  "base_channels": 32,
  "num_workers": 0,
  "seed": 20260516,
  "threshold": 0.5,
  "early_stopping_patience": 18,
  "early_stopping_min_delta": 0.001,
  "modes": ["rgb", "depth", "rgbd"],
  "loss": {
    "name": "BCEWithLogitsLoss",
    "pos_weight": "auto_from_train_split"
  },
  "depth_normalization": {
    "type": "per_image_percentile",
    "lower_percentile": 1,
    "upper_percentile": 99
  },
  "outputs": {
    "root": "REPLACE_WITH_LOCAL_OUTPUT_ROOT/baselines",
    "save_best_metric": "val_iou",
    "save_prediction_previews": 12
  }
}
